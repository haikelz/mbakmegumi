---
import FadeContent from "@/components/fade-content";
import MagicBento from "@/components/magic-bento";
import Layout from "@/layout/Layout.astro";
import "@/styles/global.css";
---

<Layout
  title="Megumi Kato"
  description="Haikel's Wife"
  url="https://megumi.ekel.dev"
>
  <section class="z-30 w-full max-w-7xl p-[clamp(0.5rem,1.5vw,1rem)]">
    <div
      class="grid grid-cols-1 gap-[clamp(0.75rem,1.8vw,1.2rem)] lg:grid-cols-[minmax(0,1.35fr)_minmax(0,1fr)_minmax(0,0.92fr)] lg:items-stretch"
    >
      <div
        class="border-4 border-[#111] bg-[#ffe658] p-[clamp(0.95rem,1.8vw,1.35rem)] text-[#111] shadow-[8px_8px_0_#111] transition-transform duration-150 hover:translate-x-[-3px] hover:translate-y-[-3px] lg:col-span-2 lg:row-1 lg:min-h-[300px]"
      >
        <span
          class="inline-block border-[3px] border-[#111] bg-white px-[0.65rem] py-[0.2rem] text-xs font-bold uppercase tracking-[0.12em]"
          >MY BELOVED</span
        >
        <h1
          class="mt-[0.7rem] text-[clamp(2rem,6.6vw,5.7rem)] font-black uppercase leading-[0.92] tracking-[0.02em] text-balance"
        >
          MEGUMI KATO
        </h1>
        <p
          class="mt-3 max-w-[60ch] text-[clamp(0.95rem,1.65vw,1.1rem)] font-bold leading-[1.45]"
        >
          It’s not like I want something like a confession. I’m fine with a
          chance to fall in love, just a little. I just want simple, casual
          words. Words that can make one say, “ah, so I could fall in love just
          like that…
        </p>
      </div>
      <div
        class="border-4 border-[#111] bg-[#58e8ff] p-[clamp(0.95rem,1.8vw,1.35rem)] text-[#111] shadow-[8px_8px_0_#111] transition-transform duration-150 hover:translate-x-[-3px] hover:translate-y-[-3px] lg:col-3 lg:row-1"
      >
        <div class="text-[0.78rem] font-black uppercase tracking-[0.12em]">
          HUSBAND
        </div>
        <div
          class="mt-[0.7rem] text-[clamp(1.5rem,4.6vw,3rem)] font-black uppercase leading-[0.95]"
        >
          HAIKEL
        </div>
      </div>
    </div>
    <FadeContent
      blur={false}
      duration={500}
      easing="ease-out"
      initialOpacity={0}
      client:only="react"
      className="relative z-50 mt-5 md:mt-7"
    >
      <div
        class="border-4 border-[#111] bg-[#111] p-[clamp(0.6rem,1vw,0.9rem)] text-white shadow-[8px_8px_0_#111] transition-transform duration-150 hover:translate-x-[-3px] hover:translate-y-[-3px]"
      >
        <MagicBento
          textAutoHide={true}
          enableStars={false}
          enableSpotlight={false}
          enableBorderGlow={false}
          enableTilt={false}
          enableMagnetism={false}
          clickEffect={false}
          spotlightRadius={180}
          particleCount={0}
          client:only="react"
        />
      </div>
    </FadeContent>
  </section>
</Layout>
